# ── Pinecone (vector memory) ──────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=company-research

# ── OpenAI (embeddings only — for Pinecone save/search) ──────────────────────
# Used exclusively for text-embedding-ada-002
# NOT used for copy generation — that runs through Claude (your subscription)
OPENAI_API_KEY=your_openai_api_key_here

# ── Notion MCP ────────────────────────────────────────────────────────────────
NOTION_API_KEY=your_notion_integration_token_here

# ── Google Workspace CLI (optional) ───────────────────────────────────────────
# Only needed if using /deep-research with Google Drive upload
# Setup: https://github.com/googleworkspace/cli
# After gws auth login, credentials are stored by the gws CLI — no tokens here
